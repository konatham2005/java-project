package project;

import java.sql.*;

public class db {

    public static Connection getConnection() {

        Connection con = null;

        try {

            Class.forName("com.mysql.cj.jdbc.Driver");

            con = DriverManager.getConnection(
                "jdbc:mysql://localhost:3306/attendance_db",
                "root",
                "password"
            );

        } catch(Exception e) {
            e.printStackTrace();
        }

        return con;
    }
}










